# =============================================================
# PixelsSuite Automated Testing – .gitignore
# Covers: Maven/TestNG (Pathum), Selenium (Reshmi),
#         Playwright (Jayalath), Cypress (Jeesara)
# =============================================================


# ─────────────────────────────────────────
# Node.js (Playwright & Cypress)
# ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnp
.pnp.js
# package-lock.json  ← intentionally NOT ignored; commit it for reproducible installs


# ─────────────────────────────────────────
# Playwright (Member1-Jayalath-Playwright)
# ─────────────────────────────────────────
# Test results & reports
Member1-Jayalath-Playwright/test-results/
Member1-Jayalath-Playwright/playwright-report/
Member1-Jayalath-Playwright/.playwright/
# Screenshots & videos captured during runs
Member1-Jayalath-Playwright/screenshots/
Member1-Jayalath-Playwright/videos/


# ─────────────────────────────────────────
# Cypress (Member3-Jeesara-Cypress)
# ─────────────────────────────────────────
# Test artifacts
Member3-Jeesara-Cypress/cypress/videos/
Member3-Jeesara-Cypress/cypress/screenshots/
Member3-Jeesara-Cypress/cypress/downloads/
Member3-Jeesara-Cypress/cypress/fixtures/example.json
# Cypress cache (local machine specific)
.cache/Cypress/


# ─────────────────────────────────────────
# Maven / Java (Member2-Reshmi-Selenium &
#               Member4-Pathum-TestNG)
# ─────────────────────────────────────────
# Build output
target/
*/target/

# Maven wrapper (optional, keep if committed intentionally)
# .mvn/wrapper/maven-wrapper.jar

# Compiled class files
*.class

# JAR / WAR / EAR / ZIP artifacts
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Surefire & Failsafe reports (generated, not source)
**/surefire-reports/
**/failsafe-reports/

# TestNG output
test-output/
*/test-output/

# Screenshots generated by Selenium / TestNG tests
Member2-Reshmi-Selenium/screenshots/
Member4-Pathum-TestNG/screenshots/


# ─────────────────────────────────────────
# IDE – IntelliJ IDEA
# ─────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/

# IDE – Eclipse / STS
.project
.classpath
.settings/
bin/
*.launch

# IDE – VS Code
.vscode/
*.code-workspace

# IDE – NetBeans
nbproject/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/


# ─────────────────────────────────────────
# Operating System
# ─────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~


# ─────────────────────────────────────────
# Logs & temp files
# ─────────────────────────────────────────
*.log
logs/
*.tmp
*.temp
*.swp
*.swo


# ─────────────────────────────────────────
# Environment / secrets
# ─────────────────────────────────────────
.env
.env.*
!.env.example
secrets.properties
