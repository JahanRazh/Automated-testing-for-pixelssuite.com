{
  "name": "pixelssuite-cypress-tests",
  "version": "1.0.0",
  "description": "Cypress E2E tests for pixelssuite.com — Member 3: Jeesara",
  "scripts": {
    "test": "cypress run",
    "test:open": "cypress open",
    "test:chrome": "cypress run --browser chrome",
    "test:compress": "cypress run --spec 'cypress/e2e/compress_page.cy.js'",
    "test:convert": "cypress run --spec 'cypress/e2e/convert_navigation.cy.js'",
    "test:gif": "cypress run --spec 'cypress/e2e/gif_compressor.cy.js'"
  },
  "devDependencies": {
    "cypress": "^13.8.1"
  }
}
